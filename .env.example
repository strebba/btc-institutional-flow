# Copia questo file come .env e popola i valori opzionali

# CoinGlass API key (Startup tier) — NON committare su git
COINGLASS_API_KEY=

# Telegram (opzionale – per alert real-time)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Webhook Telegram (opzionale, per /recap on-demand dal gruppo)
TELEGRAM_WEBHOOK_URL=
TELEGRAM_WEBHOOK_SECRET=

# Trigger esterno daily recap — chiave condivisa con GitHub Actions cron.
# Genera con: openssl rand -hex 32. Stessa stringa va nei secrets del repo
# come TELEGRAM_RECAP_KEY (vedi .github/workflows/daily-recap.yml).
TELEGRAM_RECAP_KEY=

# Override user-agent SEC (opzionale)
EDGAR_USER_AGENT=

# Override path DB (opzionale)
DB_PATH=

# CORS origins per FastAPI (separati da virgola, opzionale)
# CORS_ORIGINS=https://seashell-app-h7hc4.ondigitalocean.app,http://localhost:3000
